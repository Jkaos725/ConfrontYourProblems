[sub_resource type="GDScript" id="GDScript_x6lq5"]
script/source = "extends PanelContainer

func _ready():
    # Hide the tooltip initially
    hide()

func update_text(text_content):
    # Update the RichTextLabel's text
    $RichTextLabel.text = text_content

func show_tooltip():
    show()
    # Ensure it follows the cursor
    set_process(true)

func hide_tooltip():
    hide()
    set_process(false)

func _process(delta):
    # Optional offset for better placement
    var offset = Vector2(10, 20)
    global_position = get_global_mouse_position() + offset

