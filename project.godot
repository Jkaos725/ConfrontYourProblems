;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ConfrontYourProblems"
run/main_scene="uid://dpexvfyfft0cv"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Global="*uid://hsaxpgapeh0r"

[file_customization]

folder_colors={
"res://Images/": "red",
"res://Scenes/": "blue",
"res://Scripts/": "green"
}

[global_group]

